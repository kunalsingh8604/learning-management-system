# Copy to .env for local development with a remote PostgreSQL database.
# On Vercel, add these in Project → Settings → Environment Variables.

# Supabase: Project Settings → Database → Connection string → URI (Session mode)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Optional: auto-create admin on Vercel startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_EMAIL=you@example.com

# Required on Vercel for HTTPS forms (comma-separated)
CSRF_TRUSTED_ORIGINS=https://learning-management-system-theta-blush.vercel.app
