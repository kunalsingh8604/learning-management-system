# ============================================================
# Production PostgreSQL — copy this file to .env and fill values
# ============================================================
#
# Supabase se connection string kaise lein:
# 1. https://supabase.com par sign up karein
# 2. New Project banayein (password yaad rakhein)
# 3. Project Settings -> Database -> Connection string -> URI
# 4. "Session pooler" select karein (port 6543)
# 5. [YOUR-PASSWORD] ko apne password se replace karein
#
# Example:
# DATABASE_URL=postgresql://postgres.abcdef:MyPass123@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

DATABASE_URL=

SECRET_KEY=change-this-to-a-long-random-string
DEBUG=False

ADMIN_USERNAME=Kunalsingh86
ADMIN_PASSWORD=YourSecurePassword123
ADMIN_EMAIL=kunalsinghk2003@gmail.com

CSRF_TRUSTED_ORIGINS=https://learning-management-system-theta-blush.vercel.app,https://learning-management-system-efy4.vercel.app
